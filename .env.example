# =============================================================================
# LSPU KMIS — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# [REQUIRED] = app crashes or feature breaks if absent.
# [OPTIONAL] = degrades gracefully (feature disabled).
# [DEV ONLY] = only needed for local development.
# =============================================================================


# ── Application ───────────────────────────────────────────────────────────────

NODE_ENV=development

# [REQUIRED for production] Full public URL of your deployed app.
# Render: set to https://your-app-name.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4007
NEXT_PUBLIC_API_BASE_URL=http://localhost:4007/api


# ── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL full connection URL
DATABASE_URL=postgresql://kmis_user:secure_password_change_me@localhost:5432/lspu_kmis

# [REQUIRED] Direct DB URL for Prisma (same as DATABASE_URL when not using a pooler)
DIRECT_URL=postgresql://kmis_user:secure_password_change_me@localhost:5432/lspu_kmis

# [DEV ONLY] Used by docker-compose to configure the Postgres container
DB_USER=kmis_user
DB_PASSWORD=secure_password_change_me
DB_NAME=lspu_kmis


# ── Security ──────────────────────────────────────────────────────────────────

# [REQUIRED in production] Override the default hardcoded JWT secret.
# Generate: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars


# ── Azure Blob Storage ────────────────────────────────────────────────────────
# [REQUIRED] — The app throws a hard error if these are missing.
# All file uploads/downloads depend on Azure Blob Storage.
# Get from: Azure Portal → Storage Account → Access Keys

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccountname

# [OPTIONAL] Defaults to 'repository-files' in code
# AZURE_STORAGE_CONTAINER_NAME=repository-files


# ── Redis / Upstash ───────────────────────────────────────────────────────────
# [OPTIONAL] Without this, caching falls back to in-memory (per-process, ephemeral).
# Sign up at https://console.upstash.com — free tier available.

UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# [OPTIONAL] Upstash Vector for similarity search
# UPSTASH_VECTOR_REST_URL=https://your-vector-id.upstash.io
# UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token

# [DEV ONLY] Local Redis URL used by docker-compose only
REDIS_URL=redis://localhost:6379


# ── Colivara Vector Search ────────────────────────────────────────────────────
# [OPTIONAL] Document embedding and semantic search. Feature disabled if unset.

# COLIVARA_API_KEY=your_colivara_api_key
# COLIVARA_API_ENDPOINT=https://colivara.com/api/v1


# ── Google Gemini AI ──────────────────────────────────────────────────────────
# [OPTIONAL] Used for AI text generation in QPRO analysis.

# GOOGLE_AI_API_KEY=your_google_ai_api_key


# ── OpenAI / OpenRouter ───────────────────────────────────────────────────────
# [OPTIONAL] Used for embeddings and AI generation routing.

# OPENAI_API_KEY=your_openai_or_openrouter_api_key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1


# ── Qwen AI ───────────────────────────────────────────────────────────────────
# [OPTIONAL] Chat search and AI generation via Qwen model.

# QWEN_API_KEY=your_qwen_api_key
# QWEN_MODEL=qwen/qwen-2.5-vl-72b-instruct
# QWEN_BASE_URL=https://openrouter.ai/api/v1
# QWEN_MAX_TOKENS=2048


# ── Supabase (optional — for image hosting only) ──────────────────────────────
# [OPTIONAL] Only needed if you use Supabase for image storage.
# Set hostname (no https://) to override the default in next.config.mjs.

# NEXT_PUBLIC_SUPABASE_HOSTNAME=yourprojectid.supabase.co
# SUPABASE_URL=https://yourprojectid.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key


# ── AI Rate Limiting & Tuning ─────────────────────────────────────────────────
# [OPTIONAL] All have sensible defaults built in.

# AI_MAX_REQUESTS_PER_HOUR=60
# AI_REQUEST_TIMEOUT=30000
# API_KEY_ROTATION_INTERVAL_HOURS=24
# SALT_ROUNDS=12


# ── Logging ───────────────────────────────────────────────────────────────────
# [OPTIONAL] Defaults to true. Set to false to reduce log noise.

# LOG_PERFORMANCE=true
# LOG_ERRORS=true
# LOG_USAGE=true
# PERFORMANCE_THRESHOLD_MS=5000
